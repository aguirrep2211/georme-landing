# Odoo 19: JSON-2
ODOO_API_MODE=json2
ODOO_URL=https://tu-instancia.odoo.com
ODOO_DATABASE=
ODOO_API_KEY=cambia-esta-clave

# Solo para Odoo 18 o anterior con ODOO_API_MODE=xmlrpc
ODOO_USERNAME=usuario-api@georme.com

# Opcionales: identificadores numéricos existentes en Odoo
ODOO_SOURCE_ID=
ODOO_TEAM_ID=

# Campo personalizado numérico opcional, por ejemplo x_studio_web_score
ODOO_SCORE_FIELD=

# Protección básica contra abuso por IP
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=600
